DOMAIN=rollstudy.online
PUBLIC_APP_URL=https://rollstudy.online
APP_ENV=production
HTTP_ADDR=:8080
DATABASE_URL=postgres://bjj:REPLACE_WITH_URL_ENCODED_PASSWORD@db:5432/bjj?sslmode=disable
POSTGRES_DB=bjj
POSTGRES_USER=bjj
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD
DB_CONNECT_TIMEOUT=5s
SHUTDOWN_TIMEOUT=10s
LOG_LEVEL=info
AUTH_COOKIE_SECURE=true
SESSION_IDLE_TTL=12h
SESSION_ABSOLUTE_TTL=168h
LOGIN_RATE_LIMIT=10
OBJECT_ENDPOINT=https://REGION.digitaloceanspaces.com
OBJECT_PUBLIC_ENDPOINT=https://REGION.digitaloceanspaces.com
OBJECT_REGION=REGION
OBJECT_BUCKET=REPLACE_WITH_PRIVATE_BUCKET
OBJECT_ACCESS_KEY=REPLACE_WITH_LEAST_PRIVILEGE_KEY
OBJECT_SECRET_KEY=REPLACE_WITH_SECRET
OBJECT_PATH_STYLE=false
UPLOAD_URL_TTL=15m
